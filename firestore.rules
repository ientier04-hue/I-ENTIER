rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Account data: identity and preferences, separate from health records.
    match /user/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;

      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          'displayName', 'email', 'photoUrl', 'provider', 'createdAt', 'updatedAt'
        ]);

      allow update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName', 'email', 'photoUrl', 'provider', 'updatedAt'
        ]);

      allow delete: if false;
    }

    // Medical profile: only its authenticated owner can access it.
    match /patients/{patientId} {
      allow read: if signedIn() && request.auth.uid == patientId;

      allow create: if signedIn()
        && request.auth.uid == patientId
        && request.resource.data.keys().hasOnly([
          'sex', 'birthDate', 'weightKg', 'heightCm', 'phone',
          'emergencyContact', 'address', 'bloodType', 'medicalConditions',
          'allergies', 'currentMedications', 'previousSurgeries', 'specialNeeds',
          'pregnancyStatus', 'primaryDoctor', 'insurance', 'profileComplete',
          'createdAt', 'updatedAt'
        ]);

      allow update: if signedIn()
        && request.auth.uid == patientId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'sex', 'birthDate', 'weightKg', 'heightCm', 'phone',
          'emergencyContact', 'address', 'bloodType', 'medicalConditions',
          'allergies', 'currentMedications', 'previousSurgeries', 'specialNeeds',
          'pregnancyStatus', 'primaryDoctor', 'insurance', 'profileComplete',
          'updatedAt'
        ]);

      allow delete: if false;

      // Time-series health data remains private to the patient. Measurements
      // are immutable after creation; a patient may remove an incorrect entry.
      match /healthMeasurements/{measurementId} {
        allow read: if signedIn() && request.auth.uid == patientId;

        allow create: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.keys().hasOnly([
            'kind', 'value', 'secondaryValue', 'pulseBpm', 'unit', 'context',
            'note', 'measuredAt', 'createdAt'
          ])
          && request.resource.data.keys().hasAll([
            'kind', 'value', 'unit', 'measuredAt', 'createdAt'
          ])
          && request.resource.data.kind in [
            'bloodPressure', 'bloodGlucose', 'weight', 'temperature', 'oxygen'
          ]
          && request.resource.data.value is number
          && request.resource.data.measuredAt is timestamp
          && request.resource.data.measuredAt <= request.time
          && request.resource.data.createdAt == request.time
          && request.resource.data.unit is string
          && (!request.resource.data.keys().hasAny(['context'])
            || request.resource.data.context is string)
          && (!request.resource.data.keys().hasAny(['note'])
            || (request.resource.data.note is string
              && request.resource.data.note.size() <= 300))
          && (!request.resource.data.keys().hasAny(['pulseBpm'])
            || (request.resource.data.pulseBpm is number
              && request.resource.data.pulseBpm >= 20
              && request.resource.data.pulseBpm <= 250))
          && (
            (request.resource.data.kind == 'bloodPressure'
              && request.resource.data.value >= 40
              && request.resource.data.value <= 300
              && request.resource.data.keys().hasAll(['secondaryValue'])
              && request.resource.data.secondaryValue is number
              && request.resource.data.secondaryValue >= 20
              && request.resource.data.secondaryValue <= 200)
            || (request.resource.data.kind == 'bloodGlucose'
              && request.resource.data.value >= 10
              && request.resource.data.value <= 1000)
            || (request.resource.data.kind == 'weight'
              && request.resource.data.value >= 1
              && request.resource.data.value <= 500)
            || (request.resource.data.kind == 'temperature'
              && request.resource.data.value >= 25
              && request.resource.data.value <= 45)
            || (request.resource.data.kind == 'oxygen'
              && request.resource.data.value >= 50
              && request.resource.data.value <= 100)
          );

        allow update: if false;
        allow delete: if signedIn() && request.auth.uid == patientId;
      }

      // Menstrual cycle journal. Each day can be edited as symptoms evolve;
      // predictions are calculated locally and are never stored as medical facts.
      match /cycleEntries/{entryId} {
        allow read: if signedIn() && request.auth.uid == patientId;

        allow create: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.keys().hasOnly([
            'date', 'isPeriod', 'flow', 'symptoms', 'mood', 'note',
            'createdAt', 'updatedAt'
          ])
          && request.resource.data.keys().hasAll([
            'date', 'isPeriod', 'flow', 'symptoms', 'mood', 'note',
            'createdAt', 'updatedAt'
          ])
          && request.resource.data.date is timestamp
          && request.resource.data.isPeriod is bool
          && request.resource.data.flow is string
          && request.resource.data.flow in ['', 'light', 'medium', 'heavy']
          && (request.resource.data.isPeriod
            || request.resource.data.flow == '')
          && request.resource.data.symptoms is list
          && request.resource.data.symptoms.size() <= 8
          && request.resource.data.symptoms.hasOnly([
            'cramps', 'headache', 'fatigue', 'bloating', 'backache',
            'tenderBreasts', 'nausea', 'acne'
          ])
          && request.resource.data.mood is string
          && request.resource.data.mood in [
            '', 'great', 'calm', 'sensitive', 'irritable', 'sad'
          ]
          && request.resource.data.note is string
          && request.resource.data.note.size() <= 500
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;

        allow update: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'isPeriod', 'flow', 'symptoms', 'mood', 'note', 'updatedAt'
          ])
          && request.resource.data.date is timestamp
          && request.resource.data.date == resource.data.date
          && request.resource.data.isPeriod is bool
          && request.resource.data.flow is string
          && request.resource.data.flow in ['', 'light', 'medium', 'heavy']
          && (request.resource.data.isPeriod
            || request.resource.data.flow == '')
          && request.resource.data.symptoms is list
          && request.resource.data.symptoms.size() <= 8
          && request.resource.data.symptoms.hasOnly([
            'cramps', 'headache', 'fatigue', 'bloating', 'backache',
            'tenderBreasts', 'nausea', 'acne'
          ])
          && request.resource.data.mood is string
          && request.resource.data.mood in [
            '', 'great', 'calm', 'sensitive', 'irritable', 'sad'
          ]
          && request.resource.data.note is string
          && request.resource.data.note.size() <= 500
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.updatedAt == request.time;

        allow delete: if signedIn() && request.auth.uid == patientId;
      }

      // Private emotional wellbeing journal. Entries are deliberately
      // immutable so their history cannot be silently rewritten.
      match /mentalHealthEntries/{entryId} {
        allow read: if signedIn() && request.auth.uid == patientId;

        allow create: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.keys().hasOnly([
            'mood', 'moodScore', 'feelings', 'note', 'createdAt'
          ])
          && request.resource.data.keys().hasAll([
            'mood', 'moodScore', 'feelings', 'note', 'createdAt'
          ])
          && request.resource.data.mood is string
          && request.resource.data.mood in [
            'veryLow', 'low', 'neutral', 'good', 'veryGood'
          ]
          && request.resource.data.moodScore is int
          && request.resource.data.moodScore >= 1
          && request.resource.data.moodScore <= 5
          && request.resource.data.feelings is list
          && request.resource.data.feelings.size() <= 8
          && request.resource.data.feelings.hasOnly([
            'anxious', 'sad', 'stressed', 'tired', 'lonely', 'angry',
            'calm', 'hopeful'
          ])
          && request.resource.data.note is string
          && request.resource.data.note.size() <= 500
          && request.resource.data.createdAt == request.time;

        allow update: if false;
        allow delete: if signedIn() && request.auth.uid == patientId;
      }

      // Laboratory reports are published by trusted backends and can only be
      // read by the patient who owns the private medical record.
      match /laboratoryResults/{resultId} {
        allow read: if signedIn() && request.auth.uid == patientId;
        allow write: if false;
      }

      // Private preventive-care notebook. Patients can record completed
      // check-ups and the next date agreed with a healthcare professional.
      match /preventiveCareRecords/{recordId} {
        allow read: if signedIn() && request.auth.uid == patientId;

        allow create: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.keys().hasOnly([
            'category', 'title', 'planItemId', 'completedAt', 'nextDueAt',
            'provider', 'note', 'createdAt', 'updatedAt'
          ])
          && request.resource.data.keys().hasAll([
            'category', 'title', 'planItemId', 'completedAt', 'provider',
            'note', 'createdAt', 'updatedAt'
          ])
          && request.resource.data.category is string
          && request.resource.data.category in [
            'checkup', 'vaccine', 'screening', 'dental', 'vision', 'habit'
          ]
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 120
          && request.resource.data.planItemId is string
          && request.resource.data.planItemId.size() <= 80
          && request.resource.data.completedAt is timestamp
          && request.resource.data.completedAt <= request.time
          && (!request.resource.data.keys().hasAny(['nextDueAt'])
            || (request.resource.data.nextDueAt is timestamp
              && request.resource.data.nextDueAt
                > request.resource.data.completedAt))
          && request.resource.data.provider is string
          && request.resource.data.provider.size() <= 120
          && request.resource.data.note is string
          && request.resource.data.note.size() <= 500
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;

        allow update: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'category', 'title', 'planItemId', 'completedAt', 'nextDueAt',
            'provider', 'note', 'updatedAt'
          ])
          && request.resource.data.category is string
          && request.resource.data.category in [
            'checkup', 'vaccine', 'screening', 'dental', 'vision', 'habit'
          ]
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 120
          && request.resource.data.planItemId is string
          && request.resource.data.planItemId.size() <= 80
          && request.resource.data.completedAt is timestamp
          && request.resource.data.completedAt <= request.time
          && (!request.resource.data.keys().hasAny(['nextDueAt'])
            || (request.resource.data.nextDueAt is timestamp
              && request.resource.data.nextDueAt
                > request.resource.data.completedAt))
          && request.resource.data.provider is string
          && request.resource.data.provider.size() <= 120
          && request.resource.data.note is string
          && request.resource.data.note.size() <= 500
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.updatedAt == request.time;

        allow delete: if signedIn() && request.auth.uid == patientId;
      }

      // In-app preventive reminders. They are immutable: changing a date
      // means replacing the reminder, which keeps validation predictable.
      match /preventiveCareReminders/{reminderId} {
        allow read: if signedIn() && request.auth.uid == patientId;

        allow create: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.keys().hasOnly([
            'category', 'title', 'planItemId', 'dueAt', 'note',
            'createdAt', 'updatedAt'
          ])
          && request.resource.data.keys().hasAll([
            'category', 'title', 'planItemId', 'dueAt', 'note',
            'createdAt', 'updatedAt'
          ])
          && request.resource.data.category is string
          && request.resource.data.category in [
            'checkup', 'vaccine', 'screening', 'dental', 'vision', 'habit'
          ]
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 120
          && request.resource.data.planItemId is string
          && request.resource.data.planItemId.size() <= 80
          && request.resource.data.dueAt is timestamp
          && request.resource.data.note is string
          && request.resource.data.note.size() <= 300
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;

        allow update: if false;
        allow delete: if signedIn() && request.auth.uid == patientId;
      }

      // Notification feed and scheduled alerts. Firestore is the shared source
      // of truth; each signed-in device mirrors future entries to its local
      // notification scheduler.
      match /notifications/{notificationId} {
        allow read: if signedIn() && request.auth.uid == patientId;

        allow create: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.keys().hasOnly([
            'title', 'message', 'type', 'isRead', 'scheduledAt',
            'actionLabel', 'source', 'sourceId', 'createdAt', 'updatedAt'
          ])
          && request.resource.data.keys().hasAll([
            'title', 'message', 'type', 'isRead', 'source', 'sourceId',
            'createdAt', 'updatedAt'
          ])
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 120
          && request.resource.data.message is string
          && request.resource.data.message.size() > 0
          && request.resource.data.message.size() <= 300
          && request.resource.data.type in [
            'appointment', 'result', 'reminder', 'security'
          ]
          && request.resource.data.isRead is bool
          && request.resource.data.source in [
            'app', 'preventiveReminder', 'preventiveRecord',
            'laboratoryResult', 'prescription', 'appointment', 'security'
          ]
          && request.resource.data.sourceId is string
          && request.resource.data.sourceId.size() <= 120
          && (!request.resource.data.keys().hasAny(['scheduledAt'])
            || request.resource.data.scheduledAt is timestamp)
          && (!request.resource.data.keys().hasAny(['actionLabel'])
            || (request.resource.data.actionLabel is string
              && request.resource.data.actionLabel.size() <= 80))
          && request.resource.data.createdAt is timestamp
          && request.resource.data.createdAt <= request.time
          && request.resource.data.updatedAt == request.time;

        allow update: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'isRead', 'updatedAt'
          ])
          && request.resource.data.isRead is bool
          && request.resource.data.updatedAt == request.time;

        allow delete: if signedIn() && request.auth.uid == patientId;
      }

      // Scanned prescriptions belong to the patient. A trusted backend can
      // later create records with source == 'doctor' through the Admin SDK.
      match /prescriptions/{prescriptionId} {
        allow read: if signedIn() && request.auth.uid == patientId;

        allow create: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.keys().hasOnly([
            'fileName', 'storagePath', 'source', 'status', 'doctorId',
            'doctorName', 'issuedAt', 'expiresAt', 'createdAt', 'updatedAt'
          ])
          && request.resource.data.keys().hasAll([
            'fileName', 'storagePath', 'source', 'status', 'createdAt',
            'updatedAt'
          ])
          && request.resource.data.fileName is string
          && request.resource.data.fileName.size() <= 250
          && request.resource.data.storagePath is string
          && request.resource.data.storagePath.matches(
            'prescriptions/' + patientId + '/.*'
          )
          && request.resource.data.source == 'scan'
          && request.resource.data.status == 'available'
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;

        allow update: if false;
        allow delete: if signedIn() && request.auth.uid == patientId;
      }

    }

    // Directories are readable after authentication, but data management must
    // be handled by an admin backend or the Firebase console.
    match /personnelMedical/{documentId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /institution/{documentId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Deny every collection not explicitly listed above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
