rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(
          /databases/$(database)/documents/administrators/$(request.auth.uid)
        )
        && get(
          /databases/$(database)/documents/administrators/$(request.auth.uid)
        ).data.active == true;
    }

    function validProviderProfile(data) {
      return data.keys().hasOnly([
          'ownerUid', 'accountType', 'displayName', 'category',
          'registrationNumber', 'contactPerson', 'workplace', 'phone', 'email',
          'address', 'description', 'experience', 'qualifications', 'services',
          'schedule', 'available', 'isVisible', 'verificationStatus',
          'rejectionReason', 'termsAccepted', 'createdAt', 'updatedAt'
        ])
        && data.keys().hasAll([
          'ownerUid', 'accountType', 'displayName', 'category',
          'registrationNumber', 'contactPerson', 'workplace', 'phone', 'email',
          'address', 'description', 'experience', 'qualifications', 'services',
          'schedule', 'available', 'isVisible', 'verificationStatus',
          'rejectionReason', 'termsAccepted', 'createdAt', 'updatedAt'
        ])
        && data.accountType in ['professional', 'institution']
        && data.displayName is string
        && data.displayName.size() > 1
        && data.displayName.size() <= 140
        && data.category is string
        && data.category.size() > 1
        && data.category.size() <= 120
        && data.registrationNumber is string
        && data.registrationNumber.size() > 1
        && data.registrationNumber.size() <= 120
        && data.contactPerson is string
        && data.contactPerson.size() <= 140
        && data.workplace is string
        && data.workplace.size() <= 160
        && data.phone is string
        && data.phone.size() > 4
        && data.phone.size() <= 40
        && data.email is string
        && data.email.size() > 4
        && data.email.size() <= 180
        && data.address is string
        && data.address.size() > 3
        && data.address.size() <= 300
        && data.description is string
        && data.description.size() > 3
        && data.description.size() <= 1500
        && data.experience is string
        && data.experience.size() <= 300
        && data.qualifications is string
        && data.qualifications.size() <= 800
        && data.services is string
        && data.services.size() > 1
        && data.services.size() <= 1200
        && data.schedule is string
        && data.schedule.size() > 1
        && data.schedule.size() <= 500
        && data.available is bool
        && data.isVisible is bool
        && data.verificationStatus in ['pending', 'approved', 'rejected']
        && data.rejectionReason is string
        && data.rejectionReason.size() <= 600
        && data.termsAccepted == true
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function providerMayPublish(type) {
      let profile = getAfter(
        /databases/$(database)/documents/providerProfiles/$(request.auth.uid)
      );
      return signedIn()
        && profile.data.ownerUid == request.auth.uid
        && profile.data.accountType == type
        && profile.data.verificationStatus == 'approved'
        && profile.data.isVisible == true;
    }

    function appointmentProviderExists(data) {
      return (
          data.providerType == 'professional'
          && exists(
            /databases/$(database)/documents/personnelMedical/$(data.providerId)
          )
          && get(
            /databases/$(database)/documents/personnelMedical/$(data.providerId)
          ).data.ownerUid == data.providerId
          && get(
            /databases/$(database)/documents/personnelMedical/$(data.providerId)
          ).data.disponible == true
        )
        || (
          data.providerType == 'institution'
          && exists(
            /databases/$(database)/documents/institution/$(data.providerId)
          )
          && get(
            /databases/$(database)/documents/institution/$(data.providerId)
          ).data.ownerUid == data.providerId
          && (
            !get(
              /databases/$(database)/documents/institution/$(data.providerId)
            ).data.keys().hasAny(['disponible'])
            || get(
              /databases/$(database)/documents/institution/$(data.providerId)
            ).data.disponible == true
          )
        );
    }

    function validProfessionalDirectory(data, ownerId) {
      return data.keys().hasOnly([
          'ownerUid', 'nomComplet', 'specialite', 'etablissement', 'biographie',
          'experience', 'qualification', 'services', 'horaires', 'adresse',
          'telephone', 'email', 'disponible', 'isPublished',
          'verificationStatus', 'createdAt', 'updatedAt'
        ])
        && data.keys().hasAll([
          'ownerUid', 'nomComplet', 'specialite', 'etablissement', 'biographie',
          'experience', 'qualification', 'services', 'horaires', 'adresse',
          'telephone', 'email', 'disponible', 'isPublished',
          'verificationStatus', 'createdAt', 'updatedAt'
        ])
        && data.ownerUid == ownerId
        && data.nomComplet is string
        && data.nomComplet.size() > 1
        && data.nomComplet.size() <= 140
        && data.specialite is string
        && data.specialite.size() > 1
        && data.specialite.size() <= 120
        && data.etablissement is string
        && data.etablissement.size() <= 160
        && data.biographie is string
        && data.biographie.size() <= 1500
        && data.experience is string
        && data.experience.size() <= 300
        && data.qualification is string
        && data.qualification.size() <= 800
        && data.services is string
        && data.services.size() <= 1200
        && data.horaires is string
        && data.horaires.size() <= 500
        && data.adresse is string
        && data.adresse.size() <= 300
        && data.telephone is string
        && data.telephone.size() <= 40
        && data.email is string
        && data.email.size() <= 180
        && data.disponible is bool
        && data.isPublished == true
        && data.verificationStatus == 'approved'
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function validInstitutionDirectory(data, ownerId) {
      return data.keys().hasOnly([
          'ownerUid', 'nom', 'type', 'description', 'services', 'horaires',
          'adresse', 'telephone', 'email', 'disponible', 'isPublished',
          'verificationStatus', 'createdAt', 'updatedAt'
        ])
        && data.keys().hasAll([
          'ownerUid', 'nom', 'type', 'description', 'services', 'horaires',
          'adresse', 'telephone', 'email', 'disponible', 'isPublished',
          'verificationStatus', 'createdAt', 'updatedAt'
        ])
        && data.ownerUid == ownerId
        && data.nom is string
        && data.nom.size() > 1
        && data.nom.size() <= 160
        && data.type is string
        && data.type.size() > 1
        && data.type.size() <= 120
        && data.description is string
        && data.description.size() <= 1500
        && data.services is string
        && data.services.size() <= 1200
        && data.horaires is string
        && data.horaires.size() <= 500
        && data.adresse is string
        && data.adresse.size() <= 300
        && data.telephone is string
        && data.telephone.size() <= 40
        && data.email is string
        && data.email.size() <= 180
        && data.disponible is bool
        && data.isPublished == true
        && data.verificationStatus == 'approved'
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // Administrator roles are provisioned outside client applications. A
    // signed-in user may read its own role to learn whether access is active,
    // but no client can create, modify, or delete an administrator.
    match /administrators/{adminId} {
      allow get: if signedIn()
        && (request.auth.uid == adminId || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }

    // Account data: identity and preferences, separate from health records.
    match /user/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;

      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          'displayName', 'email', 'photoUrl', 'provider', 'createdAt', 'updatedAt'
        ]);

      allow update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName', 'email', 'photoUrl', 'provider', 'updatedAt'
        ]);

      allow delete: if false;
    }

    // Medical profile: only its authenticated owner can access it.
    match /patients/{patientId} {
      allow read: if signedIn() && request.auth.uid == patientId;

      allow create: if signedIn()
        && request.auth.uid == patientId
        && request.resource.data.keys().hasOnly([
          'sex', 'birthDate', 'weightKg', 'heightCm', 'phone',
          'emergencyContact', 'address', 'bloodType', 'medicalConditions',
          'allergies', 'currentMedications', 'previousSurgeries', 'specialNeeds',
          'pregnancyStatus', 'primaryDoctor', 'insurance', 'profileComplete',
          'createdAt', 'updatedAt'
        ]);

      allow update: if signedIn()
        && request.auth.uid == patientId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'sex', 'birthDate', 'weightKg', 'heightCm', 'phone',
          'emergencyContact', 'address', 'bloodType', 'medicalConditions',
          'allergies', 'currentMedications', 'previousSurgeries', 'specialNeeds',
          'pregnancyStatus', 'primaryDoctor', 'insurance', 'profileComplete',
          'updatedAt'
        ]);

      allow delete: if false;

      // Time-series health data remains private to the patient. Measurements
      // are immutable after creation; a patient may remove an incorrect entry.
      match /healthMeasurements/{measurementId} {
        allow read: if signedIn() && request.auth.uid == patientId;

        allow create: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.keys().hasOnly([
            'kind', 'value', 'secondaryValue', 'pulseBpm', 'unit', 'context',
            'note', 'measuredAt', 'createdAt'
          ])
          && request.resource.data.keys().hasAll([
            'kind', 'value', 'unit', 'measuredAt', 'createdAt'
          ])
          && request.resource.data.kind in [
            'bloodPressure', 'bloodGlucose', 'weight', 'temperature', 'oxygen'
          ]
          && request.resource.data.value is number
          && request.resource.data.measuredAt is timestamp
          && request.resource.data.measuredAt <= request.time
          && request.resource.data.createdAt == request.time
          && request.resource.data.unit is string
          && (!request.resource.data.keys().hasAny(['context'])
            || request.resource.data.context is string)
          && (!request.resource.data.keys().hasAny(['note'])
            || (request.resource.data.note is string
              && request.resource.data.note.size() <= 300))
          && (!request.resource.data.keys().hasAny(['pulseBpm'])
            || (request.resource.data.pulseBpm is number
              && request.resource.data.pulseBpm >= 20
              && request.resource.data.pulseBpm <= 250))
          && (
            (request.resource.data.kind == 'bloodPressure'
              && request.resource.data.value >= 40
              && request.resource.data.value <= 300
              && request.resource.data.keys().hasAll(['secondaryValue'])
              && request.resource.data.secondaryValue is number
              && request.resource.data.secondaryValue >= 20
              && request.resource.data.secondaryValue <= 200)
            || (request.resource.data.kind == 'bloodGlucose'
              && request.resource.data.value >= 10
              && request.resource.data.value <= 1000)
            || (request.resource.data.kind == 'weight'
              && request.resource.data.value >= 1
              && request.resource.data.value <= 500)
            || (request.resource.data.kind == 'temperature'
              && request.resource.data.value >= 25
              && request.resource.data.value <= 45)
            || (request.resource.data.kind == 'oxygen'
              && request.resource.data.value >= 50
              && request.resource.data.value <= 100)
          );

        allow update: if false;
        allow delete: if signedIn() && request.auth.uid == patientId;
      }

      // Menstrual cycle journal. Each day can be edited as symptoms evolve;
      // predictions are calculated locally and are never stored as medical facts.
      match /cycleEntries/{entryId} {
        allow read: if signedIn() && request.auth.uid == patientId;

        allow create: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.keys().hasOnly([
            'date', 'isPeriod', 'flow', 'symptoms', 'mood', 'note',
            'createdAt', 'updatedAt'
          ])
          && request.resource.data.keys().hasAll([
            'date', 'isPeriod', 'flow', 'symptoms', 'mood', 'note',
            'createdAt', 'updatedAt'
          ])
          && request.resource.data.date is timestamp
          && request.resource.data.isPeriod is bool
          && request.resource.data.flow is string
          && request.resource.data.flow in ['', 'light', 'medium', 'heavy']
          && (request.resource.data.isPeriod
            || request.resource.data.flow == '')
          && request.resource.data.symptoms is list
          && request.resource.data.symptoms.size() <= 8
          && request.resource.data.symptoms.hasOnly([
            'cramps', 'headache', 'fatigue', 'bloating', 'backache',
            'tenderBreasts', 'nausea', 'acne'
          ])
          && request.resource.data.mood is string
          && request.resource.data.mood in [
            '', 'great', 'calm', 'sensitive', 'irritable', 'sad'
          ]
          && request.resource.data.note is string
          && request.resource.data.note.size() <= 500
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;

        allow update: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'isPeriod', 'flow', 'symptoms', 'mood', 'note', 'updatedAt'
          ])
          && request.resource.data.date is timestamp
          && request.resource.data.date == resource.data.date
          && request.resource.data.isPeriod is bool
          && request.resource.data.flow is string
          && request.resource.data.flow in ['', 'light', 'medium', 'heavy']
          && (request.resource.data.isPeriod
            || request.resource.data.flow == '')
          && request.resource.data.symptoms is list
          && request.resource.data.symptoms.size() <= 8
          && request.resource.data.symptoms.hasOnly([
            'cramps', 'headache', 'fatigue', 'bloating', 'backache',
            'tenderBreasts', 'nausea', 'acne'
          ])
          && request.resource.data.mood is string
          && request.resource.data.mood in [
            '', 'great', 'calm', 'sensitive', 'irritable', 'sad'
          ]
          && request.resource.data.note is string
          && request.resource.data.note.size() <= 500
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.updatedAt == request.time;

        allow delete: if signedIn() && request.auth.uid == patientId;
      }

      // Private emotional wellbeing journal. Entries are deliberately
      // immutable so their history cannot be silently rewritten.
      match /mentalHealthEntries/{entryId} {
        allow read: if signedIn() && request.auth.uid == patientId;

        allow create: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.keys().hasOnly([
            'mood', 'moodScore', 'feelings', 'note', 'createdAt'
          ])
          && request.resource.data.keys().hasAll([
            'mood', 'moodScore', 'feelings', 'note', 'createdAt'
          ])
          && request.resource.data.mood is string
          && request.resource.data.mood in [
            'veryLow', 'low', 'neutral', 'good', 'veryGood'
          ]
          && request.resource.data.moodScore is int
          && request.resource.data.moodScore >= 1
          && request.resource.data.moodScore <= 5
          && request.resource.data.feelings is list
          && request.resource.data.feelings.size() <= 8
          && request.resource.data.feelings.hasOnly([
            'anxious', 'sad', 'stressed', 'tired', 'lonely', 'angry',
            'calm', 'hopeful'
          ])
          && request.resource.data.note is string
          && request.resource.data.note.size() <= 500
          && request.resource.data.createdAt == request.time;

        allow update: if false;
        allow delete: if signedIn() && request.auth.uid == patientId;
      }

      // Laboratory reports are published by trusted backends and can only be
      // read by the patient who owns the private medical record.
      match /laboratoryResults/{resultId} {
        allow read: if signedIn() && request.auth.uid == patientId;
        allow write: if false;
      }

      // Private preventive-care notebook. Patients can record completed
      // check-ups and the next date agreed with a healthcare professional.
      match /preventiveCareRecords/{recordId} {
        allow read: if signedIn() && request.auth.uid == patientId;

        allow create: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.keys().hasOnly([
            'category', 'title', 'planItemId', 'completedAt', 'nextDueAt',
            'provider', 'note', 'createdAt', 'updatedAt'
          ])
          && request.resource.data.keys().hasAll([
            'category', 'title', 'planItemId', 'completedAt', 'provider',
            'note', 'createdAt', 'updatedAt'
          ])
          && request.resource.data.category is string
          && request.resource.data.category in [
            'checkup', 'vaccine', 'screening', 'dental', 'vision', 'habit'
          ]
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 120
          && request.resource.data.planItemId is string
          && request.resource.data.planItemId.size() <= 80
          && request.resource.data.completedAt is timestamp
          && request.resource.data.completedAt <= request.time
          && (!request.resource.data.keys().hasAny(['nextDueAt'])
            || (request.resource.data.nextDueAt is timestamp
              && request.resource.data.nextDueAt
                > request.resource.data.completedAt))
          && request.resource.data.provider is string
          && request.resource.data.provider.size() <= 120
          && request.resource.data.note is string
          && request.resource.data.note.size() <= 500
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;

        allow update: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'category', 'title', 'planItemId', 'completedAt', 'nextDueAt',
            'provider', 'note', 'updatedAt'
          ])
          && request.resource.data.category is string
          && request.resource.data.category in [
            'checkup', 'vaccine', 'screening', 'dental', 'vision', 'habit'
          ]
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 120
          && request.resource.data.planItemId is string
          && request.resource.data.planItemId.size() <= 80
          && request.resource.data.completedAt is timestamp
          && request.resource.data.completedAt <= request.time
          && (!request.resource.data.keys().hasAny(['nextDueAt'])
            || (request.resource.data.nextDueAt is timestamp
              && request.resource.data.nextDueAt
                > request.resource.data.completedAt))
          && request.resource.data.provider is string
          && request.resource.data.provider.size() <= 120
          && request.resource.data.note is string
          && request.resource.data.note.size() <= 500
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.updatedAt == request.time;

        allow delete: if signedIn() && request.auth.uid == patientId;
      }

      // In-app preventive reminders. They are immutable: changing a date
      // means replacing the reminder, which keeps validation predictable.
      match /preventiveCareReminders/{reminderId} {
        allow read: if signedIn() && request.auth.uid == patientId;

        allow create: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.keys().hasOnly([
            'category', 'title', 'planItemId', 'dueAt', 'note',
            'createdAt', 'updatedAt'
          ])
          && request.resource.data.keys().hasAll([
            'category', 'title', 'planItemId', 'dueAt', 'note',
            'createdAt', 'updatedAt'
          ])
          && request.resource.data.category is string
          && request.resource.data.category in [
            'checkup', 'vaccine', 'screening', 'dental', 'vision', 'habit'
          ]
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 120
          && request.resource.data.planItemId is string
          && request.resource.data.planItemId.size() <= 80
          && request.resource.data.dueAt is timestamp
          && request.resource.data.note is string
          && request.resource.data.note.size() <= 300
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;

        allow update: if false;
        allow delete: if signedIn() && request.auth.uid == patientId;
      }

      // Notification feed and scheduled alerts. Firestore is the shared source
      // of truth; each signed-in device mirrors future entries to its local
      // notification scheduler.
      match /notifications/{notificationId} {
        allow read: if signedIn() && request.auth.uid == patientId;

        allow create: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.keys().hasOnly([
            'title', 'message', 'type', 'isRead', 'scheduledAt',
            'actionLabel', 'source', 'sourceId', 'createdAt', 'updatedAt'
          ])
          && request.resource.data.keys().hasAll([
            'title', 'message', 'type', 'isRead', 'source', 'sourceId',
            'createdAt', 'updatedAt'
          ])
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 120
          && request.resource.data.message is string
          && request.resource.data.message.size() > 0
          && request.resource.data.message.size() <= 300
          && request.resource.data.type in [
            'appointment', 'result', 'reminder', 'security'
          ]
          && request.resource.data.isRead is bool
          && request.resource.data.source in [
            'app', 'preventiveReminder', 'preventiveRecord',
            'laboratoryResult', 'prescription', 'appointment', 'security'
          ]
          && request.resource.data.sourceId is string
          && request.resource.data.sourceId.size() <= 120
          && (!request.resource.data.keys().hasAny(['scheduledAt'])
            || request.resource.data.scheduledAt is timestamp)
          && (!request.resource.data.keys().hasAny(['actionLabel'])
            || (request.resource.data.actionLabel is string
              && request.resource.data.actionLabel.size() <= 80))
          && request.resource.data.createdAt is timestamp
          && request.resource.data.createdAt <= request.time
          && request.resource.data.updatedAt == request.time;

        // A provider response is committed in the same batch as the matching
        // appointment decision. The deterministic identifier prevents a
        // provider from flooding a patient's feed for one request.
        allow create: if signedIn()
          && request.auth.uid != patientId
          && request.resource.data.keys().hasOnly([
            'title', 'message', 'type', 'isRead', 'actionLabel', 'source',
            'sourceId', 'createdAt', 'updatedAt'
          ])
          && request.resource.data.keys().hasAll([
            'title', 'message', 'type', 'isRead', 'actionLabel', 'source',
            'sourceId', 'createdAt', 'updatedAt'
          ])
          && notificationId
            == 'appointment_' + request.resource.data.sourceId
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 120
          && request.resource.data.message is string
          && request.resource.data.message.size() > 0
          && request.resource.data.message.size() <= 300
          && request.resource.data.type == 'appointment'
          && request.resource.data.isRead == false
          && request.resource.data.actionLabel == 'Voir le rendez-vous'
          && request.resource.data.source == 'appointment'
          && request.resource.data.sourceId is string
          && request.resource.data.sourceId.size() > 0
          && request.resource.data.sourceId.size() <= 120
          && get(
            /databases/$(database)/documents/appointments/$(request.resource.data.sourceId)
          ).data.patientId == patientId
          && get(
            /databases/$(database)/documents/appointments/$(request.resource.data.sourceId)
          ).data.providerId == request.auth.uid
          && get(
            /databases/$(database)/documents/appointments/$(request.resource.data.sourceId)
          ).data.status == 'pending'
          && getAfter(
            /databases/$(database)/documents/appointments/$(request.resource.data.sourceId)
          ).data.status in ['confirmed', 'cancelled']
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;

        allow update: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'isRead', 'updatedAt'
          ])
          && request.resource.data.isRead is bool
          && request.resource.data.updatedAt == request.time;

        allow delete: if signedIn() && request.auth.uid == patientId;
      }

      // Scanned prescriptions belong to the patient. A trusted backend can
      // later create records with source == 'doctor' through the Admin SDK.
      match /prescriptions/{prescriptionId} {
        allow read: if signedIn() && request.auth.uid == patientId;

        allow create: if signedIn()
          && request.auth.uid == patientId
          && request.resource.data.keys().hasOnly([
            'fileName', 'storagePath', 'source', 'status', 'doctorId',
            'doctorName', 'issuedAt', 'expiresAt', 'createdAt', 'updatedAt'
          ])
          && request.resource.data.keys().hasAll([
            'fileName', 'storagePath', 'source', 'status', 'createdAt',
            'updatedAt'
          ])
          && request.resource.data.fileName is string
          && request.resource.data.fileName.size() <= 250
          && request.resource.data.storagePath is string
          && request.resource.data.storagePath.matches(
            'prescriptions/' + patientId + '/.*'
          )
          && request.resource.data.source == 'scan'
          && request.resource.data.status == 'available'
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;

        allow update: if false;
        allow delete: if signedIn() && request.auth.uid == patientId;
      }

    }

    // Appointment requests are shared only between the patient who created
    // them and the selected provider. A provider decision must atomically
    // create the matching patient notification.
    match /appointments/{appointmentId} {
      allow read: if signedIn()
        && (
          resource.data.patientId == request.auth.uid
          || resource.data.providerId == request.auth.uid
        );

      allow create: if signedIn()
        && appointmentId.size() > 0
        && appointmentId.size() <= 120
        && request.auth.uid == request.resource.data.patientId
        && request.resource.data.keys().hasOnly([
          'patientId', 'patientName', 'providerId', 'providerType',
          'providerName', 'service', 'appointmentMode', 'location',
          'scheduledAt', 'scheduleLabel', 'status', 'patientNote',
          'responseNote', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'patientId', 'patientName', 'providerId', 'providerType',
          'providerName', 'service', 'appointmentMode', 'location',
          'scheduledAt', 'scheduleLabel', 'status', 'patientNote',
          'responseNote', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.patientId is string
        && request.resource.data.patientName is string
        && request.resource.data.patientName.size() > 0
        && request.resource.data.patientName.size() <= 140
        && request.resource.data.providerId is string
        && request.resource.data.providerId.size() > 0
        && request.resource.data.providerId.size() <= 128
        && request.resource.data.providerType
          in ['professional', 'institution']
        && request.resource.data.providerName is string
        && request.resource.data.providerName.size() > 0
        && request.resource.data.providerName.size() <= 160
        && request.resource.data.service is string
        && request.resource.data.service.size() <= 160
        && request.resource.data.appointmentMode
          in ['inPerson', 'homeVisit', 'video']
        && request.resource.data.location is string
        && request.resource.data.location.size() <= 300
        && (
          request.resource.data.appointmentMode != 'homeVisit'
          || request.resource.data.location.size() > 3
        )
        && request.resource.data.scheduledAt is timestamp
        && request.resource.data.scheduledAt
          > request.time + duration.value(30, 'm')
        && request.resource.data.scheduledAt
          < request.time + duration.value(366, 'd')
        && request.resource.data.scheduleLabel is string
        && request.resource.data.scheduleLabel.size() > 0
        && request.resource.data.scheduleLabel.size() <= 500
        && request.resource.data.status == 'pending'
        && request.resource.data.patientNote is string
        && request.resource.data.patientNote.size() <= 500
        && request.resource.data.responseNote == ''
        && appointmentProviderExists(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if signedIn()
        && resource.data.providerId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'responseNote', 'respondedAt', 'updatedAt'
        ])
        && request.resource.data.status in ['confirmed', 'cancelled']
        && request.resource.data.responseNote is string
        && request.resource.data.responseNote.size() <= 500
        && request.resource.data.respondedAt == request.time
        && request.resource.data.updatedAt == request.time
        && getAfter(
          /databases/$(database)/documents/patients/$(resource.data.patientId)/notifications/appointment_$(appointmentId)
        ).data.source == 'appointment'
        && getAfter(
          /databases/$(database)/documents/patients/$(resource.data.patientId)/notifications/appointment_$(appointmentId)
        ).data.sourceId == appointmentId
        && getAfter(
          /databases/$(database)/documents/patients/$(resource.data.patientId)/notifications/appointment_$(appointmentId)
        ).data.createdAt == request.time;

      allow delete: if false;
    }

    // Provider applications are private. Providers manage their identity and
    // presentation; active administrators may read requests and set only the
    // fields needed for a review decision.
    match /providerProfiles/{providerId} {
      allow read: if signedIn()
        && (request.auth.uid == providerId || isAdmin());

      allow create: if signedIn()
        && request.auth.uid == providerId
        && validProviderProfile(request.resource.data)
        && request.resource.data.ownerUid == providerId
        && request.resource.data.verificationStatus == 'pending'
        && request.resource.data.rejectionReason == ''
        && request.resource.data.isVisible == false
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if signedIn()
        && request.auth.uid == providerId
        && validProviderProfile(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName', 'category', 'registrationNumber', 'contactPerson',
          'workplace', 'phone', 'email', 'address', 'description', 'experience',
          'qualifications', 'services', 'schedule', 'available', 'isVisible',
          'termsAccepted', 'updatedAt'
        ])
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.accountType == resource.data.accountType
        && request.resource.data.verificationStatus
          == resource.data.verificationStatus
        && request.resource.data.rejectionReason
          == resource.data.rejectionReason
        && request.resource.data.createdAt == resource.data.createdAt
        && (resource.data.verificationStatus == 'approved'
          || request.resource.data.isVisible == false)
        && request.resource.data.updatedAt == request.time;

      allow update: if isAdmin()
        && validProviderProfile(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'verificationStatus', 'rejectionReason', 'isVisible', 'updatedAt'
        ])
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.accountType == resource.data.accountType
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.verificationStatus
          in ['approved', 'rejected']
        && request.resource.data.verificationStatus
          != resource.data.verificationStatus
        && request.resource.data.isVisible == false
        && (
          (request.resource.data.verificationStatus == 'rejected'
            && request.resource.data.rejectionReason is string
            && request.resource.data.rejectionReason.size() > 0
            && request.resource.data.rejectionReason.size() <= 600)
          || (request.resource.data.verificationStatus == 'approved'
            && request.resource.data.rejectionReason == '')
        )
        && request.resource.data.updatedAt == request.time;

      allow delete: if false;
    }

    // Every decision made by the administration interface creates a separate,
    // immutable audit record. Audit records are never visible to providers.
    match /providerReviews/{reviewId} {
      allow read: if isAdmin();

      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          'profileId', 'adminUid', 'previousStatus', 'newStatus', 'reason',
          'createdAt'
        ])
        && request.resource.data.keys().hasAll([
          'profileId', 'adminUid', 'previousStatus', 'newStatus', 'reason',
          'createdAt'
        ])
        && request.resource.data.profileId is string
        && request.resource.data.profileId.size() > 0
        && request.resource.data.profileId.size() <= 128
        && request.resource.data.adminUid == request.auth.uid
        && request.resource.data.previousStatus
          in ['pending', 'approved', 'rejected']
        && request.resource.data.newStatus in ['approved', 'rejected']
        && request.resource.data.previousStatus
          != request.resource.data.newStatus
        && get(
          /databases/$(database)/documents/providerProfiles/$(request.resource.data.profileId)
        ).data.verificationStatus == request.resource.data.previousStatus
        && getAfter(
          /databases/$(database)/documents/providerProfiles/$(request.resource.data.profileId)
        ).data.verificationStatus == request.resource.data.newStatus
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 600
        && (
          (request.resource.data.newStatus == 'rejected'
            && request.resource.data.reason.size() > 0)
          || (request.resource.data.newStatus == 'approved'
            && request.resource.data.reason == '')
        )
        && request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }

    // Verified providers manage only their own public directory document.
    // Removing a listing remains possible even if verification is revoked.
    match /personnelMedical/{documentId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.auth.uid == documentId
        && providerMayPublish('professional')
        && validProfessionalDirectory(request.resource.data, documentId)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if signedIn()
        && request.auth.uid == documentId
        && resource.data.ownerUid == request.auth.uid
        && providerMayPublish('professional')
        && validProfessionalDirectory(request.resource.data, documentId)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;

      allow delete: if isAdmin()
        || (signedIn()
          && request.auth.uid == documentId
          && resource.data.ownerUid == request.auth.uid);
    }

    match /institution/{documentId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.auth.uid == documentId
        && providerMayPublish('institution')
        && validInstitutionDirectory(request.resource.data, documentId)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if signedIn()
        && request.auth.uid == documentId
        && resource.data.ownerUid == request.auth.uid
        && providerMayPublish('institution')
        && validInstitutionDirectory(request.resource.data, documentId)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;

      allow delete: if isAdmin()
        || (signedIn()
          && request.auth.uid == documentId
          && resource.data.ownerUid == request.auth.uid);
    }

    // Deny every collection not explicitly listed above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
